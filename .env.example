# TrustButVerify Backend — Environment Configuration
# Copy this file to .env and fill in the values.
#
#   cp .env.example .env

# ── MySQL ────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=change_me_root
MYSQL_DATABASE=trustbutverify
MYSQL_USER=trustbutverify
MYSQL_PASSWORD=change_me_pass

# ── FastAPI / SQLAlchemy ─────────────────────────────
DATABASE_URL=mysql+aiomysql://trustbutverify:change_me_pass@db:3306/trustbutverify
API_HOST=0.0.0.0
API_PORT=8000
